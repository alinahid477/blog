# skills-repo git credentials
# Copy this file to .env.secrets and fill in real values.
# .env.secrets is gitignored — never commit it.
#
# For GitHub: GIT_PASSWORD is a Personal Access Token (PAT) with 'repo' read scope.
# For GitLab: use a Project Access Token with 'read_repository' scope.

GIT_USERNAME=<your-git-username>
GIT_PASSWORD=<your-git-password>
